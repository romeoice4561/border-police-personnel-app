# ──────────────────────────────────────────────────────────────────────────────
# .env.local.example — copy to .env.local and fill in your values.
# Never commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────────────────────
# Supabase Postgres connection string (via PgBouncer for the runtime).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct (non-pooled) connection — required for Prisma migrations.
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# ── Supabase project (required) ───────────────────────────────────────────────
# Your Supabase project URL (Settings → API → Project URL).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Supabase anon / public key (Settings → API → Project API keys → anon public).
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-anon-key>"

# ── Supabase Storage — officer file uploads (feature) ─────────────────────────
# Service-role secret key (Settings → API → Project API keys → service_role).
# Required for portrait and document uploads. Keep secret — server only.
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"

# Bucket names — create these buckets in your Supabase project under Storage.
# Defaults are used when these variables are absent.
# SUPABASE_PORTRAIT_BUCKET="officer-portraits"
# SUPABASE_DOCUMENT_BUCKET="officer-documents"

# ── OpenAI (optional feature) ────────────────────────────────────────────────
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o"

# ── Google Drive (optional feature) ──────────────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
# GOOGLE_DRIVE_ROOT_FOLDER="<folder-id>"
