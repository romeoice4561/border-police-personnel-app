// Production Persistence Layer (Phase 12).
//
// Relational schema for persisting exported personnel data (exports/*.json)
// into PostgreSQL (Supabase-compatible). This schema does NOT change the AI
// pipeline — it is a downstream sink for the JSON the pipeline already
// produces. No UI, no business logic here; just the persistence model.
//
// Idempotency is enforced at the schema level: Officer.officerId is unique
// (upsert key) and each Timeline row is unique per (officerId, sequence), so
// re-importing the same exports creates no duplicate officers or timelines.

// Prisma 7 official generator (Phase 16B). The legacy `prisma-client-js`
// generated into node_modules and left a `node_modules/@prisma/client`
// symlink that the Netlify/OpenNext function bundler cannot re-create
// (EPERM: symlink). The `prisma-client` generator emits plain TS sources to a
// source-tree path instead, so there is no node_modules symlink to bundle.
generator client {
  provider     = "prisma-client"
  output       = "../lib/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URLs live in prisma.config.ts (for migrate/
  // introspection) and the PrismaClient driver adapter (for runtime) — not in
  // this schema file. See lib/database/database.ts and prisma.config.ts.
}

/// One officer. `officerId` is the deterministic id from the knowledge layer
/// (region/source-file), used as the idempotent upsert key.
model Officer {
  id               Int        @id @default(autoincrement())
  officerId        String     @unique
  rank             String
  firstName        String
  lastName         String
  currentPosition  String?
  currentUnit      String?
  phone            String?
  careerYears      Int        @default(0)
  qualityScore     Int?
  knowledgeScore   Int?
  region           String?
  confidence       Int?
  // Phase 17B: Google Drive photo identity, preserved from the Drive import
  // metadata (no re-scan, no re-download). All nullable — an officer imported
  // from a non-Drive source (or before this phase) simply has no photo.
  driveFileId      String?
  thumbnailUrl     String?
  webViewUrl       String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Phase 20C: optional links to the Organization master data (Phase 20A),
  // resolved from currentUnit/region/timeline text via OrganizationService.
  // Nullable and additive — the existing text fields (region, currentUnit,
  // Timeline.unit) are UNCHANGED and remain the source of truth. SetNull so
  // removing a Region/Battalion/Company can never block or cascade into
  // Officer rows. Never backfilled by this phase.
  regionRef        Region?    @relation(fields: [regionId], references: [id], onDelete: SetNull)
  regionId         Int?
  battalionRef     Battalion? @relation(fields: [battalionId], references: [id], onDelete: SetNull)
  battalionId      Int?
  companyRef       Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId        Int?
  // Phase 26B Part C/H: optional link to the top-level Headquarters (see
  // Headquarters model docs). Nullable/additive, same SetNull convention as
  // regionId/battalionId/companyId above.
  headquartersRef  Headquarters? @relation(fields: [headquartersId], references: [id], onDelete: SetNull)
  headquartersId   Int?

  // Phase 23A: Officer Profile Workspace — additional contact channels.
  // All nullable/additive; existing `phone`/Phone[] are unchanged and remain
  // the primary phone. These are flat fields (matching the existing
  // phone/region flat-field style) rather than a separate Contact table.
  email            String?
  lineId           String?
  facebookUrl      String?
  // Phase 26B Part 5 Part C/I: nickname is shown alongside the other contact
  // channels (Phone/Email/LINE/Facebook/Nickname), not a separate section.
  nickname         String?

  // Phase 26B Part 5 Part G: Personal Information, extending Basic
  // Information. All nullable/additive — every existing officer simply has
  // these unset until a human fills them in; nothing is backfilled or
  // guessed. dateOfBirth is stored as a real DATE (Thai Buddhist Era is a
  // DISPLAY concern only — see thai_date.ts's yearBEToGregorian/
  // yearGregorianToBE — so the column itself is a normal Gregorian date).
  // bloodGroup/rh/maritalStatus/shirtSize/nationality are free-form TEXT
  // (not a DB enum) so the UI's dropdowns can offer curated suggestions
  // while still accepting a "Custom" value, exactly like Rank/Position/Unit
  // already do (see lib/officer_profile/*_options.ts) — never a closed set
  // that could silently blank an imported/edited value outside the list.
  dateOfBirth      DateTime? @db.Date
  bloodGroup       String?
  rh               String?
  maritalStatus    String?
  children         Int?
  homeProvince     String?
  shirtSize        String?
  nationality      String?

  // Phase 26B Part 5 Part O (optional improvements — all nullable/additive,
  // no regression risk). Free-form TEXT throughout for the same
  // "curated-suggestion, never a closed set" reason as the Part G fields
  // above. retirementYear/retirementCountdown are intentionally NOT stored
  // columns — Part O labels them "Auto Calculated", so they are derived at
  // read time from dateOfBirth (see lib/officer_profile/retirement.ts),
  // never persisted, so they can never drift from the source date.
  citizenId        String?
  passportNumber   String?
  employeeNumber   String?
  emergencyContact String?
  emergencyPhone   String?
  addressSummary   String?
  currentProvince  String?
  religion         String?
  educationLevel   String?
  weightKg         Float?
  heightCm         Float?
  uniformShoeSize  String?
  hatSize          String?
  jacketSize       String?

  // Phase 26A: Official Portrait Architecture. A single pinned pointer to the
  // ProfilePhoto row that is this officer's OFFICIAL portrait — displayed
  // everywhere (header, list, dashboard, search) in preference to any Drive
  // scan/manual match. Nullable: most officers have no official portrait yet,
  // in which case the existing resolver tiers (Manual Upload > Manual Match >
  // Google Drive Portrait > Placeholder) are unchanged. SetNull (not Cascade)
  // so deleting/reassigning a ProfilePhoto row can never cascade into Officer;
  // in practice ProfilePhoto rows are never deleted (portrait history is
  // permanent — see ProfilePhoto.photoType docs), so this should stay set
  // once assigned. officialPortraitId is a real relation (unlike
  // ProfilePhoto.matchedOfficerId's loose string match) because it is a
  // single canonical pointer, not a discovery-time best-guess link.
  officialPortrait   ProfilePhoto? @relation("OfficialPortrait", fields: [officialPortraitId], references: [id], onDelete: SetNull)
  officialPortraitId Int?

  timeline         Timeline[]
  phones           Phone[]
  education        Education[]
  training         Training[]
  salaryHistory    SalaryHistory[]
  /// Phase 29A: Officer Document Vault — every document uploaded for this officer.
  documents        OfficerDocument[]

  @@index([rank])
  @@index([currentUnit])
  @@index([phone])
  @@index([lastName])
  @@index([headquartersId])
  @@index([regionId])
  @@index([battalionId])
  @@index([companyId])
  @@index([officialPortraitId])
}

/// One career-timeline row for an officer. Unique per (officer, sequence) so
/// re-import replaces rather than duplicates. `year` is stored as the raw
/// source string (never re-derived here) plus a parsed numeric year when known.
model Timeline {
  id         Int     @id @default(autoincrement())
  officer    Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)
  officerId  Int
  sequence   Int
  year       String
  yearValue  Int?
  position   String
  unit       String?

  // Phase 23A: Officer Profile Workspace — editable per-row fields, additive.
  // `rank` is the officer's rank AT THAT POINT in the timeline (may differ
  // from Officer.rank, which is the CURRENT rank) — nullable since existing
  // imported rows never captured a per-entry rank. `source` records where
  // this row's data came from (free text, e.g. "OCR"/"Import"/"AI"/
  // "เจ้าหน้าที่กรอก"/"เจ้าตัวกรอก"/"ตรวจสอบแล้ว"); `verified` is the review
  // status ("ยังไม่ตรวจ" | "ตรวจแล้ว" | "ยืนยันแล้ว", defaulting to
  // unverified). Existing rows (from import) get rank=null/source=null/
  // verified=default — never backfilled, never invented.
  rank       String?
  source     String?
  verified   String  @default("ยังไม่ตรวจ")

  // Phase 41 Part 1: structured Position Level (ระดับตำแหน่ง), additive
  // alongside the free-text `position` above (never merged/altered). This is
  // the AUTHORITATIVE, system-wide source of truth for an officer's position
  // level — Commander Search, Dashboard, Statistics, Charts, Timeline &
  // Promotion Intelligence all read this structured value, and after Phase 41
  // nothing derives level from `position` TEXT at runtime again. Stored as
  // one of the closed BPP-scoped strings in lib/commander_query/position_level
  // .ts (POSITION_LEVELS: Unknown / รองสารวัตร / สารวัตร / รองผู้กำกับการ / …
  // / รองผู้บัญชาการ) — a plain string (not a DB enum) so higher command
  // levels can be appended later without a schema migration. Nullable: a
  // pre-Phase-41 row that hasn't been migrated/edited yet is NULL and is
  // treated as "Unknown" by readers; the one-time backfill migration maps
  // known `position` titles into a level and sets the rest to 'Unknown'.
  positionLevel String?

  // Phase 26B Part 3: structured date model, additive alongside the legacy
  // `year` free-text column above (never altered/dropped — every pre-26B row
  // and every Phase 25 import keeps working unchanged). `day`/`month` are
  // nullable (many legacy rows only ever recorded a year); `yearBE` is the
  // Buddhist-Era year as a real integer (distinct from `yearValue`, which is
  // a best-effort parse of the free-text `year` and may hold a Gregorian or
  // otherwise-ambiguous number). `isPresent` marks an ongoing/current
  // position (the "ปัจจุบัน" case) — when true, yearBE/month/day describe the
  // START of that position, not an end date. `effectiveDate` is a real DATE
  // auto-derived from day/month/yearBE (month/day default to 1 when unknown)
  // for sorting/range queries without re-parsing text; NULL until the row is
  // migrated (by the backfill script) or edited through the new date editor.
  day           Int?
  month         Int?
  yearBE        Int?
  isPresent     Boolean   @default(false)
  effectiveDate DateTime? @db.Date

  // Phase 26B Part C: structured organization hierarchy, additive alongside
  // the legacy free-text `unit` column above (never altered/dropped — every
  // pre-26B row and every Phase 25 import keeps working unchanged). Reuses
  // the EXISTING Region/Battalion/Company master tables (Phase 20A) plus the
  // new Headquarters table (Part H) as the "Border Patrol Division" branch of
  // that hierarchy — no parallel/duplicated organization tables. All
  // nullable/SetNull: a row not yet migrated (or one whose unit doesn't
  // resolve to a registered company/battalion/region) simply has these
  // unset, exactly like `day`/`month`/`yearBE` above for un-migrated dates.
  headquarters   Headquarters? @relation(fields: [headquartersId], references: [id], onDelete: SetNull)
  headquartersId Int?
  regionRef      Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)
  regionId       Int?
  battalionRef   Battalion?    @relation(fields: [battalionId], references: [id], onDelete: SetNull)
  battalionId    Int?
  companyRef     Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId      Int?

  // Phase 26B Part 5 Part D/H/M: a richer verification TRIAD, additive
  // alongside the existing `verified` free-text status above (never altered
  // — every pre-26B row and reader of `verified` keeps working unchanged).
  // `verificationStatus` is a new, distinct 4-value closed set
  // (VERIFIED/PENDING/REJECTED/NEEDS_REVIEW — see
  // lib/officer_profile/verification_options.ts) rather than a backfilled
  // replacement of `verified`'s 3 Thai strings, so no existing row's
  // meaning is reinterpreted and no backfill/guess is required — a row
  // simply has verificationStatus=null until a human explicitly sets it via
  // the new editor. verifiedBy/verifiedDate/verificationRemark are the
  // supporting audit fields Part H asks for.
  verificationStatus  String?
  verifiedBy          String?
  verifiedDate        DateTime? @db.Date
  verificationRemark  String?

  @@unique([officerId, sequence])
  @@index([yearValue])
  @@index([unit])
  @@index([effectiveDate])
  @@index([yearBE])
  @@index([headquartersId])
  @@index([regionId])
  @@index([battalionId])
  @@index([companyId])
  @@index([verificationStatus])
  @@index([positionLevel])
}

/// Phase 23A: one education record for an officer (year, institution, degree,
/// notes). Independent CRUD rows (not a replace-all timeline) — the UI adds/
/// edits/removes individual rows via id.
model Education {
  id          Int      @id @default(autoincrement())
  officer     Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  officerId   Int
  year        String?
  institution String
  degree      String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([officerId])
}

/// Phase 23A: one training-course record for an officer (year, course name,
/// organizing unit, notes). Independent CRUD rows, same convention as Education.
model Training {
  id           Int      @id @default(autoincrement())
  officer      Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  officerId    Int
  year         String?
  course       String
  organization String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([officerId])
}

/// Phase 28A — Career Intelligence Foundation: one salary-step result for an
/// officer for one Buddhist-Era year. Every officer receives exactly one
/// result per year (0.5/1.0/1.5/2.0 steps); `@@unique([officerId, yearBE])`
/// enforces that at the database level. Historical years are preserved
/// permanently — the UI only ever adds/edits/removes individual rows by id
/// (same independent-CRUD-rows convention as Education/Training), never a
/// replace-all timeline, so a prior year's record is never silently
/// regenerated or lost when a later year is edited.
///
/// This table is intentionally minimal (foundation only, per Phase 28A's
/// scope) — no eligibility/warning/AI-suggestion columns exist yet. Future
/// phases (2-step eligibility, promotion readiness, awards, merit reports)
/// are designed to layer on top by READING this table (via
/// career_salary_engine.ts's pure utilities) rather than needing schema
/// changes here.
model SalaryHistory {
  id         Int      @id @default(autoincrement())
  officer    Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  officerId  Int
  yearBE     Int
  salaryStep Float
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([officerId, yearBE])
  @@index([officerId])
}

/// A distinct organizational unit. Deduplicated by unique `name`.
model Unit {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  officerCount Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([name])
}

/// Phase 19B: a Gallery visual asset (every non-profile image — maps, org
/// charts, deployment/company/battalion layouts, and future visual assets).
/// Independent of the Officer/personnel tables; carries discovery metadata +
/// stored Drive image URLs only (no OCR/AI fields). `assetId` is the
/// deterministic idempotent upsert key. `category` stores the AssetCategory
/// value (e.g. "NEIGHBOR_MAP"); PROFILE assets are never persisted here.
model Asset {
  id           Int      @id @default(autoincrement())
  assetId      String   @unique
  category     String
  region       String?
  company      String?
  battalion    String?
  folderName   String?
  relativePath String
  driveFileId  String?
  thumbnailUrl String?
  webViewUrl   String?
  imageWidth   Int?
  imageHeight  Int?
  createdTime  DateTime?
  updatedTime  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Phase 22A: user-editable metadata fields added by the Metadata Editor.
  // All additive — existing rows default to empty/false; never removes old cols.
  unitName     String?
  unitNumber   String?
  /// Comma-joined keyword list (e.g. "แผนที่,หน่วยข้างเคียง"). UI splits on comma to render chips.
  keywords     String   @default("")
  description  String?
  remarks      String?
  verified     Boolean  @default(false)

  // Phase 20B: optional link to the authoritative Organization master data
  // (Phase 20A), resolved from the existing `company` text at import time.
  // Nullable and additive — `company`/`battalion`/`region` text fields are
  // unchanged and remain the source of truth for assets that don't resolve
  // to a registered Company. SetNull so removing a Company never blocks or
  // cascades into Assets.
  companyRef   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId    Int?

  @@index([category])
  @@index([region])
  @@index([company])
  @@index([battalion])
  @@index([category, region])
  @@index([category, company])
  @@index([companyId])
  @@index([verified])
  @@index([unitNumber])
}

/// Phase 26B Part C/H: top-level Royal Thai Police organization master data —
/// Headquarters (บช.ตชด., บช.น., ภ.1-9, บช.ก., รร.นรต., ...). `code` is a
/// short stable slug ("BPP", "MPB", "PROV_1", ...), unique. Standalone table
/// (not FK'd FROM Region) — most headquarters entries (รร.นรต., รพ.ตร., ...)
/// have no Region children at all, and Region.headquartersId below is
/// OPTIONAL, so this reuses the existing Region -> Battalion -> Company
/// hierarchy as its "Border Patrol Division" branch (per the explicit
/// instruction: no parallel hierarchy, no duplicated Battalion/Company data)
/// while still supporting every other RTP unit that has no Region at all.
model Headquarters {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  nameTh       String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  regions      Region[]
  timeline     Timeline[]
  officers     Officer[]

  @@index([displayOrder])
}

/// Phase 20A: authoritative organization master data — Region. `code` is the
/// bare digit string ("4"), unique. Every Battalion belongs to exactly one
/// Region. This table (not folder/OCR text) is the source of truth every
/// future module (Officers, Gallery, Portfolio, permissions, ...) reads.
model Region {
  id           Int        @id @default(autoincrement())
  code         String     @unique
  nameTh       String
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Phase 26B Part C/H: optional link to the owning Headquarters (e.g. ภาค4
  // belongs to บช.ตชด.). Nullable/additive — every pre-26B Region row simply
  // has no headquarters yet; nothing about Region's existing behavior,
  // uniqueness, or Battalion relation changes.
  headquarters   Headquarters? @relation(fields: [headquartersId], references: [id], onDelete: SetNull)
  headquartersId Int?

  battalions   Battalion[]
  officers     Officer[]
  timeline     Timeline[]
  aliases      OrganizationAlias[]

  @@index([headquartersId])
}

/// Phase 20A: authoritative organization master data — Battalion (กก.ตชด.NN).
/// `code` is the 2-digit string ("44"), unique. Belongs to one Region; has
/// many Companies.
model Battalion {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  nameTh       String
  region       Region    @relation(fields: [regionId], references: [id], onDelete: Restrict)
  regionId     Int
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  companies    Company[]
  officers     Officer[]
  timeline     Timeline[]
  aliases      OrganizationAlias[]

  @@index([regionId])
}

/// Phase 20A: authoritative organization master data — Company (ตชด.NNN).
/// `code` is the 3-digit string ("447"), unique. Belongs to one Battalion.
/// Future Officer/Asset records reference companyId instead of loose text.
model Company {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  nameTh       String
  battalion    Battalion @relation(fields: [battalionId], references: [id], onDelete: Restrict)
  battalionId  Int
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assets       Asset[]
  officers     Officer[]
  timeline     Timeline[]
  aliases      OrganizationAlias[]

  @@index([battalionId])
}

/// Phase 20A: a raw unit-reference string (from OCR/folder text/imports) that
/// could NOT be confidently mapped to the master Region/Battalion/Company
/// hierarchy. Queued here for manual review instead of polluting the master
/// data with an invented organization record.
model UnresolvedOrganizationCode {
  id           Int      @id @default(autoincrement())
  raw          String
  reason       String
  sourceModule String
  createdAt    DateTime @default(now())

  @@index([sourceModule])
}

/// Phase 27 (Organization Engine): a legacy/OCR-variant/unofficial text form
/// that maps to a real, still-registered Region/Battalion/Company row —
/// distinct from UnresolvedOrganizationCode above, which is for text that
/// maps to NOTHING. An alias exists for text that DOES resolve, just not by
/// exact/normalized match against the canonical row's own code/nameTh (e.g.
/// an observed company code that the official master list doesn't include,
/// or "กองกำกับการตำรวจตระเวนชายแดนที่ 41" for battalion "41").
///
/// Additive only — this table starts EMPTY. No existing Region/Battalion/
/// Company row is altered, relabeled, or removed by adding this table.
/// Populating it (e.g. migrating the organization_seed.ts codes that fall
/// outside the official list into aliases) is a separate, future, dedicated
/// data-migration phase — see lib/organization/organization_engine.ts's
/// module docblock for the full migration plan.
///
/// Exactly one of canonicalRegionId/canonicalBattalionId/canonicalCompanyId
/// is set, matching the level the alias resolves to (never invents a level
/// the alias text didn't specify).
model OrganizationAlias {
  id                Int       @id @default(autoincrement())
  /// The raw legacy/OCR-variant/unofficial text this alias recognizes.
  aliasText         String
  canonicalRegion    Region?    @relation(fields: [canonicalRegionId], references: [id], onDelete: Cascade)
  canonicalRegionId  Int?
  canonicalBattalion Battalion? @relation(fields: [canonicalBattalionId], references: [id], onDelete: Cascade)
  canonicalBattalionId Int?
  canonicalCompany   Company?   @relation(fields: [canonicalCompanyId], references: [id], onDelete: Cascade)
  canonicalCompanyId Int?
  /// Where this alias came from (e.g. "observed-seed-migration", "ocr-variant", "manual") — for audit, not logic.
  source            String
  createdAt         DateTime  @default(now())

  @@index([aliasText])
  @@index([canonicalRegionId])
  @@index([canonicalBattalionId])
  @@index([canonicalCompanyId])
}

/// Phase 21C: a Profile Photo — every image discovered under a Drive
/// "Profile รายบุคคล ..." folder becomes EXACTLY ONE row here, unconditionally,
/// regardless of OCR success, name recognition, or officer-match outcome.
/// Completely independent from Officer (no foreign key) — `matchedOfficerId`
/// is a plain string reference to Officer.officerId, set only when
/// matchStatus is AUTO_MATCHED or MANUAL_MATCHED. Officer.driveFileId/
/// thumbnailUrl/webViewUrl (Phase 17B) are UNCHANGED; this table does not
/// replace them, it is the universal inbox that guarantees no Profile image
/// is ever lost even when it cannot (yet) be linked to an officer.
/// `driveFileId` is the deterministic idempotent upsert key.
model ProfilePhoto {
  id               Int      @id @default(autoincrement())
  driveFileId      String   @unique
  thumbnailUrl     String?
  webViewUrl       String?
  filename         String
  folderPath       String
  region           String?
  company          String?
  battalion        String?
  ocrText          String?
  ocrStatus        String   @default("PENDING")
  matchStatus      String   @default("UNASSIGNED")
  matchedOfficerId String?
  confidence       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Phase 24B-1: Officer Portrait Upload. Additive columns so an uploaded
  // portrait reuses this exact table (no new storage entity). Existing
  // Drive-discovered rows keep these at their defaults/null — unchanged.
  //   sourceType   — where the row came from: "DRIVE_SCAN" (existing inbox
  //                  rows, the default) or "UPLOAD" (portrait uploaded via the
  //                  Officer Profile). Google Drive stays read-only; uploads
  //                  never touch Drive.
  //   storagePath  — Supabase Storage object path for an uploaded portrait
  //                  (null for Drive-scanned rows). The bytes live in Supabase
  //                  Storage; thumbnailUrl/webViewUrl hold the public URLs.
  //   mimeType/width/height — captured image metadata (spec).
  //   uploadedBy   — who uploaded it (free-text actor id; nullable).
  //   isProfile    — whether this is the CURRENT portrait for the linked
  //                  officer. On a new upload the prior current portrait is set
  //                  to false and the new row to true — old portraits are never
  //                  deleted (portrait history).
  sourceType       String   @default("DRIVE_SCAN")
  storagePath      String?
  mimeType         String?
  width            Int?
  height           Int?
  uploadedBy       String?
  isProfile        Boolean  @default(false)

  // Phase 24B-2: Legacy Portrait Verification. Additive columns — existing
  // rows default to UNKNOWN/null (safe, non-destructive migration).
  //   classification — what the IMAGE ITSELF actually shows, independent of
  //                    matchStatus (who/what it's linked to). Set by a Gallery
  //                    reviewer via the verification UI, or "REAL_PERSON" for
  //                    an officer-uploaded portrait (Phase 24B-1 uploads are
  //                    self-evidently a real portrait). One of:
  //                    REAL_PERSON | PROFILE_CARD | ORGANIZATION | MAP |
  //                    DOCUMENT | UNKNOWN (default). The resolver's
  //                    "Verified Drive Portrait" tier requires
  //                    classification=REAL_PERSON; every other classification
  //                    is EXCLUDED from ever becoming a portrait, regardless
  //                    of matchStatus.
  //   classifiedBy   — reviewer actor id (nullable; null until classified).
  //   classifiedAt   — when the classification was set (nullable).
  classification   String   @default("UNKNOWN")
  classifiedBy     String?
  classifiedAt     DateTime?

  // Phase 26A: Official Portrait Architecture. `photoType` records WHAT this
  // image fundamentally IS, independent of `classification` (what the
  // reviewer verified the content shows) and `isProfile`/matchStatus (which
  // one is currently the resolved portrait):
  //   GOOGLE_PROFILE_CARD — the original Drive-scanned profile card (Phase 25
  //                          rebuild default for every existing row). MUST
  //                          NEVER be overwritten or deleted — it is the
  //                          permanent historical document (Part 13).
  //   OFFICIAL_PORTRAIT   — a portrait explicitly designated as the officer's
  //                          official photo (via upload or "Set as Official").
  //   UPLOADED            — a manual upload not (yet) designated official.
  //   OTHER               — anything else (future use).
  // Existing rows all default to GOOGLE_PROFILE_CARD (a safe, accurate
  // backfill — every pre-26A row came from the Phase 25 Drive rebuild); the
  // migration additionally sets photoType=UPLOADED for existing rows whose
  // sourceType is already "UPLOAD" (Phase 24B-1 uploads), so the two columns
  // agree from day one. This column never gates the resolver by itself —
  // `Officer.officialPortraitId` is the single source of truth for "the
  // official portrait"; photoType is descriptive metadata for the gallery/
  // history UI and future classification.
  photoType        String   @default("GOOGLE_PROFILE_CARD")

  // Opposite side of Officer.officialPortrait (Phase 26A). A ProfilePhoto can
  // be the pinned official portrait of at most one officer.
  officialPortraitOf Officer[] @relation("OfficialPortrait")

  @@index([matchStatus])
  @@index([region])
  @@index([company])
  @@index([battalion])
  @@index([matchedOfficerId])
  @@index([ocrStatus])
  @@index([sourceType])
  // Fast lookup of an officer's current portrait.
  @@index([matchedOfficerId, isProfile])
  @@index([classification])
  @@index([photoType])
}

// ─────────────────────────────────────────────────────────────────────────
// Phase 24A: Database V2 Foundation — Master Data (additive, non-destructive).
//
// Per DATABASE_V2_DESIGN.md / MASTER_DATA.md / ER_DIAGRAM.md, the V2
// foundation introduces normalized master tables that are the go-forward
// single source of truth for every future module. They are created ALONGSIDE
// the existing Phase 20A Region/Battalion/Company (Int PK) tables — nothing
// existing is renamed, dropped, or repointed. Legacy tables keep serving
// production unchanged; data migration + FK repointing happen in a later,
// dedicated phase.
//
// V2 conventions (from the authoritative docs, differing from the legacy
// Int-PK/PascalCase tables above ON PURPOSE):
//   • UUID primary keys, DB-generated via gen_random_uuid() (Principle 3).
//   • snake_case table + column names (@@map / @map).
//   • Standard columns on every table: status, version, is_deleted,
//     deleted_at, created_by, updated_by, created_at, updated_at
//     (DATABASE_V2_DESIGN §6).
//   • Every relationship by UUID FK; no text matching (Principle 5).
//   • Soft delete only — no cascade delete (ER_DIAGRAM Cascade Rules).
//
// Model names are prefixed `Master*` so they never collide with the existing
// `Region`/`Battalion`/`Company` Prisma models.
// ─────────────────────────────────────────────────────────────────────────

/// V2 master data — Region (ภาค). Top of the organization tree.
/// Example codes: REGION_1, REGION_2, REGION_SOUTH. (DATABASE_V2_DESIGN §17)
model MasterRegion {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String    @unique
  nameTh       String    @map("name_th")
  nameEn       String?   @map("name_en")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  // Standard columns (DATABASE_V2_DESIGN §6)
  status       String    @default("ACTIVE")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  commands     MasterCommand[]

  @@index([isActive])
  @@index([isDeleted])
  @@map("master_regions")
}

/// V2 master data — Command / กองบังคับการ (บก.ตชด.NN). Belongs to one Region.
/// This is the level ABOVE Subdivision that the legacy schema lacked.
/// (DATABASE_V2_DESIGN §18)
model MasterCommand {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  region       MasterRegion @relation(fields: [regionId], references: [id], onDelete: Restrict)
  regionId     String       @map("region_id") @db.Uuid
  code         String       @unique
  name         String
  displayOrder Int          @default(0) @map("display_order")
  isActive     Boolean      @default(true) @map("is_active")

  status       String       @default("ACTIVE")
  version      Int          @default(1)
  isDeleted    Boolean      @default(false) @map("is_deleted")
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?      @map("created_by") @db.Uuid
  updatedBy    String?      @map("updated_by") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  subdivisions MasterSubdivision[]

  @@index([regionId])
  @@index([isActive])
  @@index([isDeleted])
  @@map("master_commands")
}

/// V2 master data — Subdivision / กองกำกับ (กก.ตชด.NN). Belongs to one Command.
/// (DATABASE_V2_DESIGN §19)
model MasterSubdivision {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  command      MasterCommand @relation(fields: [commandId], references: [id], onDelete: Restrict)
  commandId    String        @map("command_id") @db.Uuid
  code         String        @unique
  shortName    String        @map("short_name")
  fullName     String        @map("full_name")
  province     String?
  displayOrder Int           @default(0) @map("display_order")
  isActive     Boolean       @default(true) @map("is_active")

  status       String        @default("ACTIVE")
  version      Int           @default(1)
  isDeleted    Boolean       @default(false) @map("is_deleted")
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?       @map("created_by") @db.Uuid
  updatedBy    String?       @map("updated_by") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  companies    MasterCompany[]

  @@index([commandId])
  @@index([isActive])
  @@index([isDeleted])
  @@map("master_subdivisions")
}

/// V2 master data — Company / กองร้อย (ร้อย ตชด.NNN). Belongs to one
/// Subdivision. The leaf of the organization tree an officer references.
/// (DATABASE_V2_DESIGN §20)
model MasterCompany {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subdivision   MasterSubdivision @relation(fields: [subdivisionId], references: [id], onDelete: Restrict)
  subdivisionId String            @map("subdivision_id") @db.Uuid
  code          String            @unique
  companyNo     String?           @map("company_no")
  shortName     String            @map("short_name")
  fullName      String            @map("full_name")
  location      String?
  province      String?
  latitude      Decimal?          @db.Decimal(10, 7)
  longitude     Decimal?          @db.Decimal(10, 7)
  displayOrder  Int               @default(0) @map("display_order")
  isActive      Boolean           @default(true) @map("is_active")

  status        String            @default("ACTIVE")
  version       Int               @default(1)
  isDeleted     Boolean           @default(false) @map("is_deleted")
  deletedAt     DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?           @map("created_by") @db.Uuid
  updatedBy     String?           @map("updated_by") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([subdivisionId])
  @@index([isActive])
  @@index([isDeleted])
  @@map("master_companies")
}

/// V2 master data — Rank (ยศ). Ordered by `level` (never by text comparison).
/// (DATABASE_V2_DESIGN §22)
model MasterRank {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String    @unique
  nameTh       String    @map("name_th")
  abbreviation String?
  level        Int
  groupName    String?   @map("group_name")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  status       String    @default("ACTIVE")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([level])
  @@index([isActive])
  @@index([isDeleted])
  @@map("master_ranks")
}

/// V2 master data — Position (ตำแหน่ง). Every position carries a code + Thai
/// name so spellings never diverge. (DATABASE_V2_DESIGN §23, MASTER_DATA Position)
model MasterPosition {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String    @unique
  nameTh        String    @map("name_th")
  positionGroup String?   @map("position_group")
  displayOrder  Int       @default(0) @map("display_order")
  isActive      Boolean   @default(true) @map("is_active")

  status        String    @default("ACTIVE")
  version       Int       @default(1)
  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive])
  @@index([isDeleted])
  @@map("master_positions")
}

/// V2 master data — Timeline Event Type. Every career-timeline event references
/// one of these (no free text). (DATABASE_V2_DESIGN §38)
model MasterTimelineType {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String    @unique
  nameTh       String    @map("name_th")
  nameEn       String?   @map("name_en")
  icon         String?
  color        String?
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  status       String    @default("ACTIVE")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive])
  @@index([isDeleted])
  @@map("master_timeline_types")
}

/// V2 master data — Asset Type. Classifies every Asset (Portrait, Map, GP7, …).
/// (DATABASE_V2_DESIGN §51)
model MasterAssetType {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String    @unique
  nameTh       String    @map("name_th")
  nameEn       String?   @map("name_en")
  icon         String?
  color        String?
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  status       String    @default("ACTIVE")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive])
  @@index([isDeleted])
  @@map("master_asset_types")
