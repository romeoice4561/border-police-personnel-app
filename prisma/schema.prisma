// Production Persistence Layer (Phase 12).
//
// Relational schema for persisting exported personnel data (exports/*.json)
// into PostgreSQL (Supabase-compatible). This schema does NOT change the AI
// pipeline — it is a downstream sink for the JSON the pipeline already
// produces. No UI, no business logic here; just the persistence model.
//
// Idempotency is enforced at the schema level: Officer.officerId is unique
// (upsert key) and each Timeline row is unique per (officerId, sequence), so
// re-importing the same exports creates no duplicate officers or timelines.

// Prisma 7 official generator (Phase 16B). The legacy `prisma-client-js`
// generated into node_modules and left a `node_modules/@prisma/client`
// symlink that the Netlify/OpenNext function bundler cannot re-create
// (EPERM: symlink). The `prisma-client` generator emits plain TS sources to a
// source-tree path instead, so there is no node_modules symlink to bundle.
generator client {
  provider     = "prisma-client"
  output       = "../lib/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URLs live in prisma.config.ts (for migrate/
  // introspection) and the PrismaClient driver adapter (for runtime) — not in
  // this schema file. See lib/database/database.ts and prisma.config.ts.
}

/// One officer. `officerId` is the deterministic id from the knowledge layer
/// (region/source-file), used as the idempotent upsert key.
model Officer {
  id               Int        @id @default(autoincrement())
  officerId        String     @unique
  rank             String
  firstName        String
  lastName         String
  currentPosition  String?
  currentUnit      String?
  phone            String?
  careerYears      Int        @default(0)
  qualityScore     Int?
  knowledgeScore   Int?
  region           String?
  confidence       Int?
  // Phase 17B: Google Drive photo identity, preserved from the Drive import
  // metadata (no re-scan, no re-download). All nullable — an officer imported
  // from a non-Drive source (or before this phase) simply has no photo.
  driveFileId      String?
  thumbnailUrl     String?
  webViewUrl       String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Phase 20C: optional links to the Organization master data (Phase 20A),
  // resolved from currentUnit/region/timeline text via OrganizationService.
  // Nullable and additive — the existing text fields (region, currentUnit,
  // Timeline.unit) are UNCHANGED and remain the source of truth. SetNull so
  // removing a Region/Battalion/Company can never block or cascade into
  // Officer rows. Never backfilled by this phase.
  regionRef        Region?    @relation(fields: [regionId], references: [id], onDelete: SetNull)
  regionId         Int?
  battalionRef     Battalion? @relation(fields: [battalionId], references: [id], onDelete: SetNull)
  battalionId      Int?
  companyRef       Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId        Int?

  // Phase 23A: Officer Profile Workspace — additional contact channels.
  // All nullable/additive; existing `phone`/Phone[] are unchanged and remain
  // the primary phone. These are flat fields (matching the existing
  // phone/region flat-field style) rather than a separate Contact table.
  email            String?
  lineId           String?
  facebookUrl      String?

  timeline         Timeline[]
  phones           Phone[]
  education        Education[]
  training         Training[]

  @@index([rank])
  @@index([currentUnit])
  @@index([phone])
  @@index([lastName])
  @@index([regionId])
  @@index([battalionId])
  @@index([companyId])
}

/// One career-timeline row for an officer. Unique per (officer, sequence) so
/// re-import replaces rather than duplicates. `year` is stored as the raw
/// source string (never re-derived here) plus a parsed numeric year when known.
model Timeline {
  id         Int     @id @default(autoincrement())
  officer    Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)
  officerId  Int
  sequence   Int
  year       String
  yearValue  Int?
  position   String
  unit       String?

  // Phase 23A: Officer Profile Workspace — editable per-row fields, additive.
  // `rank` is the officer's rank AT THAT POINT in the timeline (may differ
  // from Officer.rank, which is the CURRENT rank) — nullable since existing
  // imported rows never captured a per-entry rank. `source` records where
  // this row's data came from (free text, e.g. "OCR"/"Import"/"AI"/
  // "เจ้าหน้าที่กรอก"/"เจ้าตัวกรอก"/"ตรวจสอบแล้ว"); `verified` is the review
  // status ("ยังไม่ตรวจ" | "ตรวจแล้ว" | "ยืนยันแล้ว", defaulting to
  // unverified). Existing rows (from import) get rank=null/source=null/
  // verified=default — never backfilled, never invented.
  rank       String?
  source     String?
  verified   String  @default("ยังไม่ตรวจ")

  @@unique([officerId, sequence])
  @@index([yearValue])
  @@index([unit])
}

/// Phase 23A: one education record for an officer (year, institution, degree,
/// notes). Independent CRUD rows (not a replace-all timeline) — the UI adds/
/// edits/removes individual rows via id.
model Education {
  id          Int      @id @default(autoincrement())
  officer     Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  officerId   Int
  year        String?
  institution String
  degree      String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([officerId])
}

/// Phase 23A: one training-course record for an officer (year, course name,
/// organizing unit, notes). Independent CRUD rows, same convention as Education.
model Training {
  id           Int      @id @default(autoincrement())
  officer      Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  officerId    Int
  year         String?
  course       String
  organization String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([officerId])
}

/// A distinct organizational unit. Deduplicated by unique `name`.
model Unit {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  officerCount Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([name])
}

/// Phase 19B: a Gallery visual asset (every non-profile image — maps, org
/// charts, deployment/company/battalion layouts, and future visual assets).
/// Independent of the Officer/personnel tables; carries discovery metadata +
/// stored Drive image URLs only (no OCR/AI fields). `assetId` is the
/// deterministic idempotent upsert key. `category` stores the AssetCategory
/// value (e.g. "NEIGHBOR_MAP"); PROFILE assets are never persisted here.
model Asset {
  id           Int      @id @default(autoincrement())
  assetId      String   @unique
  category     String
  region       String?
  company      String?
  battalion    String?
  folderName   String?
  relativePath String
  driveFileId  String?
  thumbnailUrl String?
  webViewUrl   String?
  imageWidth   Int?
  imageHeight  Int?
  createdTime  DateTime?
  updatedTime  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Phase 22A: user-editable metadata fields added by the Metadata Editor.
  // All additive — existing rows default to empty/false; never removes old cols.
  unitName     String?
  unitNumber   String?
  /// Comma-joined keyword list (e.g. "แผนที่,หน่วยข้างเคียง"). UI splits on comma to render chips.
  keywords     String   @default("")
  description  String?
  remarks      String?
  verified     Boolean  @default(false)

  // Phase 20B: optional link to the authoritative Organization master data
  // (Phase 20A), resolved from the existing `company` text at import time.
  // Nullable and additive — `company`/`battalion`/`region` text fields are
  // unchanged and remain the source of truth for assets that don't resolve
  // to a registered Company. SetNull so removing a Company never blocks or
  // cascades into Assets.
  companyRef   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId    Int?

  @@index([category])
  @@index([region])
  @@index([company])
  @@index([battalion])
  @@index([category, region])
  @@index([category, company])
  @@index([companyId])
  @@index([verified])
  @@index([unitNumber])
}

/// Phase 20A: authoritative organization master data — Region. `code` is the
/// bare digit string ("4"), unique. Every Battalion belongs to exactly one
/// Region. This table (not folder/OCR text) is the source of truth every
/// future module (Officers, Gallery, Portfolio, permissions, ...) reads.
model Region {
  id           Int        @id @default(autoincrement())
  code         String     @unique
  nameTh       String
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  battalions   Battalion[]
  officers     Officer[]
}

/// Phase 20A: authoritative organization master data — Battalion (กก.ตชด.NN).
/// `code` is the 2-digit string ("44"), unique. Belongs to one Region; has
/// many Companies.
model Battalion {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  nameTh       String
  region       Region    @relation(fields: [regionId], references: [id], onDelete: Restrict)
  regionId     Int
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  companies    Company[]
  officers     Officer[]

  @@index([regionId])
}

/// Phase 20A: authoritative organization master data — Company (ตชด.NNN).
/// `code` is the 3-digit string ("447"), unique. Belongs to one Battalion.
/// Future Officer/Asset records reference companyId instead of loose text.
model Company {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  nameTh       String
  battalion    Battalion @relation(fields: [battalionId], references: [id], onDelete: Restrict)
  battalionId  Int
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assets       Asset[]
  officers     Officer[]

  @@index([battalionId])
}

/// Phase 20A: a raw unit-reference string (from OCR/folder text/imports) that
/// could NOT be confidently mapped to the master Region/Battalion/Company
/// hierarchy. Queued here for manual review instead of polluting the master
/// data with an invented organization record.
model UnresolvedOrganizationCode {
  id           Int      @id @default(autoincrement())
  raw          String
  reason       String
  sourceModule String
  createdAt    DateTime @default(now())

  @@index([sourceModule])
}

/// Phase 21C: a Profile Photo — every image discovered under a Drive
/// "Profile รายบุคคล ..." folder becomes EXACTLY ONE row here, unconditionally,
/// regardless of OCR success, name recognition, or officer-match outcome.
/// Completely independent from Officer (no foreign key) — `matchedOfficerId`
/// is a plain string reference to Officer.officerId, set only when
/// matchStatus is AUTO_MATCHED or MANUAL_MATCHED. Officer.driveFileId/
/// thumbnailUrl/webViewUrl (Phase 17B) are UNCHANGED; this table does not
/// replace them, it is the universal inbox that guarantees no Profile image
/// is ever lost even when it cannot (yet) be linked to an officer.
/// `driveFileId` is the deterministic idempotent upsert key.
model ProfilePhoto {
  id               Int      @id @default(autoincrement())
  driveFileId      String   @unique
  thumbnailUrl     String?
  webViewUrl       String?
  filename         String
  folderPath       String
  region           String?
  company          String?
  battalion        String?
  ocrText          String?
  ocrStatus        String   @default("PENDING")
  matchStatus      String   @default("UNASSIGNED")
  matchedOfficerId String?
  confidence       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([matchStatus])
  @@index([region])
  @@index([company])
  @@index([battalion])
  @@index([matchedOfficerId])
  @@index([ocrStatus])
}

// ─────────────────────────────────────────────────────────────────────────
// Phase 24A: Database V2 Foundation — Master Data (additive, non-destructive).
//
// Per DATABASE_V2_DESIGN.md / MASTER_DATA.md / ER_DIAGRAM.md, the V2
// foundation introduces normalized master tables that are the go-forward
// single source of truth for every future module. They are created ALONGSIDE
// the existing Phase 20A Region/Battalion/Company (Int PK) tables — nothing
// existing is renamed, dropped, or repointed. Legacy tables keep serving
// production unchanged; data migration + FK repointing happen in a later,
// dedicated phase.
//
// V2 conventions (from the authoritative docs, differing from the legacy
// Int-PK/PascalCase tables above ON PURPOSE):
//   • UUID primary keys, DB-generated via gen_random_uuid() (Principle 3).
//   • snake_case table + column names (@@map / @map).
//   • Standard columns on every table: status, version, is_deleted,
//     deleted_at, created_by, updated_by, created_at, updated_at
//     (DATABASE_V2_DESIGN §6).
//   • Every relationship by UUID FK; no text matching (Principle 5).
//   • Soft delete only — no cascade delete (ER_DIAGRAM Cascade Rules).
//
// Model names are prefixed `Master*` so they never collide with the existing
// `Region`/`Battalion`/`Company` Prisma models.
// ─────────────────────────────────────────────────────────────────────────

/// V2 master data — Region (ภาค). Top of the organization tree.
/// Example codes: REGION_1, REGION_2, REGION_SOUTH. (DATABASE_V2_DESIGN §17)
model MasterRegion {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String    @unique
  nameTh       String    @map("name_th")
  nameEn       String?   @map("name_en")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  // Standard columns (DATABASE_V2_DESIGN §6)
  status       String    @default("ACTIVE")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  commands     MasterCommand[]

  @@index([isActive])
  @@index([isDeleted])
  @@map("master_regions")
}

/// V2 master data — Command / กองบังคับการ (บก.ตชด.NN). Belongs to one Region.
/// This is the level ABOVE Subdivision that the legacy schema lacked.
/// (DATABASE_V2_DESIGN §18)
model MasterCommand {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  region       MasterRegion @relation(fields: [regionId], references: [id], onDelete: Restrict)
  regionId     String       @map("region_id") @db.Uuid
  code         String       @unique
  name         String
  displayOrder Int          @default(0) @map("display_order")
  isActive     Boolean      @default(true) @map("is_active")

  status       String       @default("ACTIVE")
  version      Int          @default(1)
  isDeleted    Boolean      @default(false) @map("is_deleted")
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?      @map("created_by") @db.Uuid
  updatedBy    String?      @map("updated_by") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  subdivisions MasterSubdivision[]

  @@index([regionId])
  @@index([isActive])
  @@index([isDeleted])
  @@map("master_commands")
}

/// V2 master data — Subdivision / กองกำกับ (กก.ตชด.NN). Belongs to one Command.
/// (DATABASE_V2_DESIGN §19)
model MasterSubdivision {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  command      MasterCommand @relation(fields: [commandId], references: [id], onDelete: Restrict)
  commandId    String        @map("command_id") @db.Uuid
  code         String        @unique
  shortName    String        @map("short_name")
  fullName     String        @map("full_name")
  province     String?
  displayOrder Int           @default(0) @map("display_order")
  isActive     Boolean       @default(true) @map("is_active")

  status       String        @default("ACTIVE")
  version      Int           @default(1)
  isDeleted    Boolean       @default(false) @map("is_deleted")
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?       @map("created_by") @db.Uuid
  updatedBy    String?       @map("updated_by") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  companies    MasterCompany[]

  @@index([commandId])
  @@index([isActive])
  @@index([isDeleted])
  @@map("master_subdivisions")
}

/// V2 master data — Company / กองร้อย (ร้อย ตชด.NNN). Belongs to one
/// Subdivision. The leaf of the organization tree an officer references.
/// (DATABASE_V2_DESIGN §20)
model MasterCompany {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subdivision   MasterSubdivision @relation(fields: [subdivisionId], references: [id], onDelete: Restrict)
  subdivisionId String            @map("subdivision_id") @db.Uuid
  code          String            @unique
  companyNo     String?           @map("company_no")
  shortName     String            @map("short_name")
  fullName      String            @map("full_name")
  location      String?
  province      String?
  latitude      Decimal?          @db.Decimal(10, 7)
  longitude     Decimal?          @db.Decimal(10, 7)
  displayOrder  Int               @default(0) @map("display_order")
  isActive      Boolean           @default(true) @map("is_active")

  status        String            @default("ACTIVE")
  version       Int               @default(1)
  isDeleted     Boolean           @default(false) @map("is_deleted")
  deletedAt     DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?           @map("created_by") @db.Uuid
  updatedBy     String?           @map("updated_by") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([subdivisionId])
  @@index([isActive])
  @@index([isDeleted])
  @@map("master_companies")
}

/// V2 master data — Rank (ยศ). Ordered by `level` (never by text comparison).
/// (DATABASE_V2_DESIGN §22)
model MasterRank {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String    @unique
  nameTh       String    @map("name_th")
  abbreviation String?
  level        Int
  groupName    String?   @map("group_name")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  status       String    @default("ACTIVE")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([level])
  @@index([isActive])
  @@index([isDeleted])
  @@map("master_ranks")
}

/// V2 master data — Position (ตำแหน่ง). Every position carries a code + Thai
/// name so spellings never diverge. (DATABASE_V2_DESIGN §23, MASTER_DATA Position)
model MasterPosition {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String    @unique
  nameTh        String    @map("name_th")
  positionGroup String?   @map("position_group")
  displayOrder  Int       @default(0) @map("display_order")
  isActive      Boolean   @default(true) @map("is_active")

  status        String    @default("ACTIVE")
  version       Int       @default(1)
  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive])
  @@index([isDeleted])
  @@map("master_positions")
}

/// V2 master data — Timeline Event Type. Every career-timeline event references
/// one of these (no free text). (DATABASE_V2_DESIGN §38)
model MasterTimelineType {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String    @unique
  nameTh       String    @map("name_th")
  nameEn       String?   @map("name_en")
  icon         String?
  color        String?
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  status       String    @default("ACTIVE")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive])
  @@index([isDeleted])
  @@map("master_timeline_types")
}

/// V2 master data — Asset Type. Classifies every Asset (Portrait, Map, GP7, …).
/// (DATABASE_V2_DESIGN §51)
model MasterAssetType {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String    @unique
  nameTh       String    @map("name_th")
  nameEn       String?   @map("name_en")
  icon         String?
  color        String?
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  status       String    @default("ACTIVE")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive])
  @@index([isDeleted])
  @@map("master_asset_types")
}

/// V2 master data — Document Type (GP7, คำสั่งแต่งตั้ง, …).
/// (DATABASE_V2_DESIGN §52)
model MasterDocumentType {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String    @unique
  nameTh       String    @map("name_th")
  nameEn       String?   @map("name_en")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  status       String    @default("ACTIVE")
  version      Int       @default(1)
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive])
  @@index([isDeleted])
  @@map("master_document_types")
}

/// A phone number associated with an officer. Unique per (officer, number).
model Phone {
  id        Int     @id @default(autoincrement())
  officer   Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)
  officerId Int
  number    String

  @@unique([officerId, number])
  @@index([number])
}

/// One database-import run, for auditing/idempotency reporting.
model ImportJob {
  id                Int         @id @default(autoincrement())
  startedAt         DateTime    @default(now())
  finishedAt        DateTime?
  images            Int         @default(0)
  imported          Int         @default(0)
  skipped           Int         @default(0)
  errors            Int         @default(0)

  logs              ImportLog[]
}

/// A per-record log line for an import job (created/updated/skipped/error).
model ImportLog {
  id          Int       @id @default(autoincrement())
  job         ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId       Int
  officerId   String
  action      String
  message     String?
  createdAt   DateTime  @default(now())

  @@index([jobId])
  @@index([officerId])
}
